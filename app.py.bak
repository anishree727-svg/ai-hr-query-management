
import streamlit as st
import sqlite3
import pandas as pd
from datetime import datetime
import io

DB_FILE = "hr_system.db"

# -----------------------
# Database helpers
# -----------------------
def get_conn():
    return sqlite3.connect(DB_FILE, check_same_thread=False)

def get_user(username, password):
    conn = get_conn()
    cur = conn.cursor()
    cur.execute("SELECT username,fullname,role FROM users WHERE username=? AND password=?", (username, password))
    row = cur.fetchone()
    conn.close()
    return row

def insert_leave(username, name, ltype, days, reason):
    conn = get_conn()
    cur = conn.cursor()
    cur.execute("INSERT INTO leave_requests(username,name,type,days,reason,status,created_at) VALUES(?,?,?,?,?,?,?)",
                (username, name, ltype, days, reason, "Pending", datetime.now().isoformat()))
    conn.commit()
    conn.close()

def query_requests(filters=None):
    conn = get_conn()
    cur = conn.cursor()
    q = "SELECT id,username,name,type,days,reason,status,created_at FROM leave_requests WHERE 1=1"
    params = []
    if filters:
        if filters.get("text"):
            q += " AND (username LIKE ? OR name LIKE ? OR reason LIKE ? OR type LIKE ?)"
            t = f"%{filters['text']}%"
            params += [t,t,t,t]
        if filters.get("status") and filters["status"] != "All":
            q += " AND status = ?"
            params.append(filters["status"])
        if filters.get("type") and filters["type"] != "All":
            q += " AND type = ?"
            params.append(filters["type"])
        if filters.get("from_date"):
            q += " AND date(created_at) >= date(?)"
            params.append(filters["from_date"])
        if filters.get("to_date"):
            q += " AND date(created_at) <= date(?)"
            params.append(filters["to_date"])
    q += " ORDER BY created_at DESC"
    df = pd.read_sql_query(q, conn, params=params)
    conn.close()
    return df

def update_status(request_id, new_status):
    conn = get_conn()
    cur = conn.cursor()
    cur.execute("UPDATE leave_requests SET status=? WHERE id=?", (new_status, request_id))
    conn.commit()
    conn.close()

# -----------------------
# Simple local chatbot (keyword-based) - multilingual hints
# -----------------------
def chatbot_reply(query):
    q = query.strip().lower()
    # very simple demo replies
    if not q:
        return "Please ask a question about leave, e.g. 'How many casual days left?'"
    if "leave" in q and "how" in q:
        return "You can submit leave via Submit Leave Request. For demo, each employee has unlimited days."
    if "approve" in q or "reject" in q:
        return "Approvals are done by Admin in the 'View All Requests' section."
    # language detection: check a few Tamil words as example
    if "eppo" in q or "enna" in q:
        return "நீங்கள் விடுமுறையை சமர்பிக்க 'Submit Leave Request' செக்ஷனை பயன்படுத்தவும்."
    if "hola" in q or "gracias" in q:
        return "Hola! Para solicitudes de permiso, use Submit Leave Request."
    # fallback echo
    return f"Demo bot: I got your question: '{query}'. For full AI, add an OpenAI key in secrets.toml."

# -----------------------
# UI: login
# -----------------------
st.set_page_config(page_title="HR Query Management", layout="wide")
st.title("HR Query Management System")

if "logged_in" not in st.session_state:
    st.session_state.logged_in = False
if "user" not in st.session_state:
    st.session_state.user = None

with st.sidebar:
    st.header("Navigation")
    if not st.session_state.logged_in:
        st.subheader("Login")
        username = st.text_input("Username")
        password = st.text_input("Password", type="password")
        if st.button("Login"):
            user = get_user(username.strip(), password.strip())
            if user:
                st.session_state.logged_in = True
                st.session_state.user = {"username": user[0], "fullname": user[1], "role": user[2]}
                st.success(f"Logged in as {user[1]} ({user[0]})")
            else:
                st.error("Invalid username or password")
        st.markdown("---")
        st.info("Demo accounts:\n\n- admin / adminpass\n- emp123 / emp123\n- anitha / anitha\n\nRun `python reset_db.py` first if DB not present.")
    else:
        st.markdown(f"**Logged in as:** {st.session_state.user['fullname']} ({st.session_state.user['username']})")
        if st.button("Logout"):
            st.session_state.logged_in = False
            st.session_state.user = None
            st.experimental_rerun()
        st.markdown("---")
        st.subheader("Choose a section")
        choice = st.radio("", ["Dashboard","Submit Leave Request","My Requests","View All Requests","Chatbot","Logout"], index=0)

# require login to see main app
if not st.session_state.logged_in:
    st.warning("Please login from the sidebar to continue.")
    st.stop()

user = st.session_state.user
role = user["role"]

# -----------------------
# Dashboard
# -----------------------
if 'choice' in locals() and choice == "Dashboard":
    st.header("Dashboard")
    df = query_requests()
    if df.empty:
        st.info("No requests yet.")
    else:
        status_counts = df['status'].value_counts()
        st.bar_chart(status_counts)
        st.dataframe(df)

# -----------------------
# Submit Leave Request (employee)
# -----------------------
elif 'choice' in locals() and choice == "Submit Leave Request":
    st.header("Submit Leave Request")
    with st.form("leave_form"):
        name = st.text_input("Full name", value=user["fullname"])
        ltype = st.selectbox("Leave type", ["Casual Leave","Sick Leave","Work From Home","Comp Off"])
        days = st.number_input("Days", min_value=1, max_value=30, value=1)
        reason = st.text_area("Reason")
        submit = st.form_submit_button("Submit")
        if submit:
            insert_leave(user["username"], name, ltype, int(days), reason)
            st.success("Leave submitted. It will appear under 'My Requests'.")

# -----------------------
# My Requests (employee)
# -----------------------
elif 'choice' in locals() and choice == "My Requests":
    st.header("My Requests")
    filters = {"text": user["username"], "status": "All"}
    df = query_requests(filters=None)
    df_user = df[df['username'] == user['username']]
    if df_user.empty:
        st.info("No requests for you.")
    else:
        st.dataframe(df_user)
        csv = df_user.to_csv(index=False).encode('utf-8')
        excel = io.BytesIO()
        with pd.ExcelWriter(excel, engine="xlsxwriter") as writer:
            df_user.to_excel(writer, index=False, sheet_name="requests")
            writer.save()
        st.download_button("Download CSV (all)", data=csv, file_name="my_requests.csv", mime="text/csv")
        st.download_button("Download Excel (all)", data=excel.getvalue(), file_name="my_requests.xlsx", mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")

# -----------------------
# View All Requests (admin)
# -----------------------
elif 'choice' in locals() and choice == "View All Requests":
    if role != "admin":
        st.error("Only admin can view this section.")
    else:
        st.header("View All Requests")

        # Filters UI
        with st.form("filter_form"):
            text = st.text_input("Search (name, reason, username, type)")
            status = st.selectbox("Status", ["All","Pending","Approved","Rejected"])
            ltype = st.selectbox("Type", ["All","Casual Leave","Sick Leave","Work From Home","Comp Off"])
            col1, col2 = st.columns(2)
            from_date = col1.date_input("From", value=None)
            to_date = col2.date_input("To", value=None)
            if st.form_submit_button("Apply Filters"):
                pass  # form will rerun and use these below

        filters = {
            "text": text.strip() if text else None,
            "status": status,
            "type": ltype,
            "from_date": from_date.isoformat() if isinstance(from_date, (datetime,)) else (from_date.isoformat() if from_date else None),
            "to_date": to_date.isoformat() if isinstance(to_date, (datetime,)) else (to_date.isoformat() if to_date else None)
        }
        df = query_requests(filters={k:v for k,v in filters.items() if v})
        st.write(f"Results: {len(df)}")

        # Action buttons for each row
        if not df.empty:
            for idx, row in df.iterrows():
                st.markdown("---")
                st.write(f"**#{row['id']} — {row['name']} ({row['username']})**")
                st.write(f"Type: {row['type']} — Days: {row['days']}")
                st.write(f"Reason: {row['reason']}")
                st.write(f"Status: {row['status']}")
                c1, c2 = st.columns([1,1])
                if row['status'] == "Pending":
                    if c1.button(f"Approve {row['id']}", key=f"appr_{row['id']}"):
                        update_status(row['id'], "Approved")
                        st.success(f"Request #{row['id']} Approved.")
                        st.experimental_rerun()
                    if c2.button(f"Reject {row['id']}", key=f"rej_{row['id']}"):
                        update_status(row['id'], "Rejected")
                        st.warning(f"Request #{row['id']} Rejected.")
                        st.experimental_rerun()
                else:
                    st.info(f"Already {row['status']}")

            csv = df.to_csv(index=False).encode('utf-8')
            excel = io.BytesIO()
            with pd.ExcelWriter(excel, engine="xlsxwriter") as writer:
                df.to_excel(writer, index=False, sheet_name="requests")
                writer.save()
            d1, d2 = st.columns(2)
            d1.download_button("Download CSV (all)", data=csv, file_name="all_requests.csv", mime="text/csv")
            d2.download_button("Download Excel (all)", data=excel.getvalue(), file_name="all_requests.xlsx", mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
        else:
            st.info("No results.")

# -----------------------
# Chatbot
# -----------------------
elif 'choice' in locals() and choice == "Chatbot":
    st.header("Multilingual HR Chatbot (Demo)")
    prompt = st.text_input("Enter your query (any language)")
    if st.button("Ask"):
        reply = chatbot_reply(prompt)
        st.success(reply)

# -----------------------
# Logout radio option
# -----------------------
elif 'choice' in locals() and choice == "Logout":
    st.session_state.logged_in = False
    st.session_state.user = None
    st.experimental_rerun()

# Fallback: show basic stats for everyone
else:
    st.header("Overview")
    df = query_requests()
    st.write("Total requests:", len(df))
    st.dataframe(df)
